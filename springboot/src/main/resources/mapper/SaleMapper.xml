<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.SaleMapper">

    <sql id="Base_Column_List">
        id,order_no,name,train_img,train_price,train_id,train_time,num,total,user_id,time,pay_no,pay_time,status
    </sql>

    <select id="selectAll" resultType="com.example.entity.Sale">
        select sale.*, user.name as userName from sale
        left join user on sale.user_id = user.id
            <where>
            <if test="orderNo != null"> and sale.order_no like concat('%', #{orderNo}, '%')</if>
            <if test="userId != null"> and sale.user_id = #{userId}</if>
        </where>
        order by sale.id desc
    </select>

    <select id="selectById" resultType="com.example.entity.Sale">
        select sale.*, user.name as userName from sale
        left join user on sale.user_id = user.id
        from sale
        where sale.id = #{id}
    </select>

    <delete id="deleteById">
        delete from sale
        where  id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.Sale" useGeneratedKeys="true" keyProperty="id">
        insert into sale
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="orderNo != null">order_no,</if>
            <if test="name != null">name,</if>
            <if test="trainImg != null">train_img,</if>
            <if test="trainPrice != null">train_price,</if>
            <if test="trainId != null">train_id,</if>
            <if test="trainTime != null">train_time,</if>
            <if test="num != null">num,</if>
            <if test="total != null">total,</if>
            <if test="userId != null">user_id,</if>
            <if test="time != null">time,</if>
            <if test="payNo != null">pay_no,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="status != null">status,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="orderNo != null">#{orderNo},</if>
            <if test="name != null">#{name},</if>
            <if test="trainImg != null">#{trainImg},</if>
            <if test="trainPrice != null">#{trainPrice},</if>
            <if test="trainId != null">#{trainId},</if>
            <if test="trainTime != null">#{trainTime},</if>
            <if test="num != null">#{num},</if>
            <if test="total != null">#{total},</if>
            <if test="userId != null">#{userId},</if>
            <if test="time != null">#{time},</if>
            <if test="payNo != null">#{payNo},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="status != null">#{status},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.Sale">
        update sale
        <set>
            <if test="orderNo != null">
                order_no = #{orderNo},
            </if>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="trainImg != null">
                train_img = #{trainImg},
            </if>
            <if test="trainPrice != null">
                train_price = #{trainPrice},
            </if>
            <if test="trainId != null">
                train_id = #{trainId},
            </if>
            <if test="trainTime != null">
                train_time = #{trainTime},
            </if>
            <if test="num != null">
                num = #{num},
            </if>
            <if test="total != null">
                total = #{total},
            </if>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="time != null">
                time = #{time},
            </if>
            <if test="payNo != null">
                pay_no = #{payNo},
            </if>
            <if test="payTime != null">
                pay_time = #{payTime},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
        </set>
        where id = #{id}
    </update>

</mapper>